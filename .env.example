# Kalshi API credentials
# Get your API Key ID from https://kalshi.com/account (under API settings)
KALSHI_KEY_ID=your_key_id_here

# The Odds API key
# Sign up at https://the-odds-api.com and copy your key from the dashboard
ODDS_API_KEY=your_api_key_here

# Kalshi private key file path (relative to project root)
# Download the .pem file from Kalshi and save it to .secrets/kalshi.pem
KALSHI_KEY_FILE=.secrets/kalshi.pem
